# Server Settings
PORT=4000
NODE_ENV=production

# PostgreSQL settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=payzo

# ZyqraPay Credentials
ZYQRAPAY_BASE_URL=https://your-zyqrapay-url
ZYQRAPAY_MERCHANT_LOGIN=your_merchant_login
ZYQRAPAY_PAY_IN_KEY=your_pay_in_key

# Callback URL (your VPS public URL)
CALLBACK_BASE_URL=https://your-domain.com

# Admin API Key
ADMIN_API_KEY=your_strong_secret_key_here
