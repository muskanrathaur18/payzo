# ============================================================
#  JetKaro — .gitignore
#  IMPORTANT: .env files kabhi bhi commit mat karo!
# ============================================================

# ----- Environment Variables -----
# .env files are included intentionally
!.env
!.env.*
!backend/.env
!frontend/.env

# ----- Node.js -----
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Frontend Build Output -----
frontend/dist/
frontend/dist-ssr/

# ----- Vite Cache -----
.vite/
frontend/.vite/

# ----- Logs -----
logs/
*.log

# ----- OS Files -----
.DS_Store
Thumbs.db

# ----- Editor -----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
