# ============================================================
#  JetKaro — .gitignore
#  IMPORTANT: .env files kabhi bhi commit mat karo!
# ============================================================

# ----- Environment Variables (NEVER COMMIT) -----
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ----- Node.js -----
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Frontend Build Output -----
frontend/dist/
frontend/dist-ssr/

# ----- Vite Cache -----
.vite/
frontend/.vite/

# ----- Logs -----
logs/
*.log

# ----- OS Files -----
.DS_Store
Thumbs.db

# ----- Editor -----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
